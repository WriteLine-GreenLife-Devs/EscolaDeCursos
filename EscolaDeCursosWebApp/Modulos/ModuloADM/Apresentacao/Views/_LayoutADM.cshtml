@using System.Security.Claims

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    @* Importação do CSS do Bootstrap *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/styles.css" />

    <title>@ViewBag.Titulo - Escola de Cursos Web</title>
</head>
<body>
    @* Barra de Navegação *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-controller="ADM" asp-action="Index">Escola de Cursos Web</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav me-auto">
                    <a class="nav-link" asp-controller="ADM" asp-action="Index">Início</a>
                    <a class="nav-link" asp-controller="ADM" asp-action="ListarAlunos">Alunos</a>
                    <a class="nav-link" asp-controller="ADM" asp-action="ListarProfessores">Professores</a>
                    <a class="nav-link" asp-controller="ADM" asp-action="ListarCategorias">Categorias</a>
                    <a class="nav-link" asp-controller="ADM" asp-action="ListarCursos">Cursos</a>
                    <a class="nav-link" asp-controller="ADM" asp-action="ListarTurmas">Turmas</a>
                </div>

                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-3 text-white ms-lg-3">
                        <div class="d-flex flex-column align-items-start align-items-lg-end">
                            <span class="fw-semibold">@User.FindFirstValue(ClaimTypes.Name)</span>
                            <small class="opacity-75">@User.FindFirstValue(ClaimTypes.Email)</small>
                        </div>

                        <form asp-controller="Usuario" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3">
                                Sair
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm rounded-pill px-3 ms-lg-3" asp-controller="Usuario" asp-action="Index">
                        Entrar
                    </a>
                }
            </div>
        </div>
    </nav>

    @* Cabeçalho da Página *@
    <header class="container py-4">
        <h2>@ViewBag.Titulo</h2>
    </header>

    @* Conteúdo da Página *@
    <main class="container pb-5">
        @RenderBody()
    </main>

    @* Importação do JavaScript do Bootstrap *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
