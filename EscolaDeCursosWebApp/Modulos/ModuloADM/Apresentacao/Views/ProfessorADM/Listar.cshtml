@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = "Professores";
}

@model List<EscolaDeCursosWebApp.Modulos.ModuloADM.Apresentacao.UsuarioADMViewModel>;

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="CadastrarProfessor">Cadastrar Novo Professor</a>
    <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="Index">Voltar ao ADM</a>
</div>

<div class="mb-4">
    <input id="searchInput" type="search" class="form-control form-control-lg" placeholder="Pesquisar professores por nome..." autocomplete="off" />
</div>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum professor cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var professor in Model)
        {
            <div class="col list-search-card">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0" data-search-name>@professor.Nome</h5>
                            <span class="badge text-bg-primary rounded-pill">Professor</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-6 text-secondary fw-semibold">Email</dt>
                            <dd class="col-6 mb-0 text-break">@professor.Email</dd>

                            <dt class="col-6 text-secondary fw-semibold">Telefone</dt>
                            <dd class="col-6 mb-0 text-break">@professor.Telefone</dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="EditarProfessor" asp-route-id="@professor.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-action="ExcluirProfessor" asp-route-id="@professor.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        const searchInput = document.getElementById('searchInput');
        if (!searchInput) return;

        const cards = Array.from(document.querySelectorAll('.list-search-card'));

        searchInput.addEventListener('input', function () {
            const term = this.value.trim().toLowerCase();
            cards.forEach(card => {
                const name = card.querySelector('[data-search-name]')?.textContent?.toLowerCase() ?? '';
                card.style.display = term === '' || name.includes(term) ? '' : 'none';
            });
        });
    })();
</script>
