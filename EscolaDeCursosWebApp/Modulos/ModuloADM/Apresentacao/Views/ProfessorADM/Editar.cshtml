@model EscolaDeCursosWebApp.Modulos.ModuloADM.Apresentacao.EditarUsuarioADMViewModel

@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = "Editar Professor";
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="EditarProfessor" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
        <input asp-for="Nome" type="text" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold">Email</label>
        <input asp-for="Email" type="email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label fw-semibold">Telefone</label>
        <input asp-for="Telefone" type="text" class="form-control" />
        <span asp-validation-for="Telefone" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Senha" class="form-label fw-semibold">Senha (deixe em branco para manter)</label>
        <input asp-for="Senha" type="password" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmarSenha" class="form-label fw-semibold">Confirmar Senha</label>
        <input asp-for="ConfirmarSenha" type="password" class="form-control" />
        <span asp-validation-for="ConfirmarSenha" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="ListarProfessores">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Salvar</button>
    </div>
</form>
