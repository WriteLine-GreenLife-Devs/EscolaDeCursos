@model List<EscolaDeCursosWebApp.Modulos.ModuloCategoria.Dominio.Categoria>

@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = "Categorias";
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="CadastrarCategoria">Cadastrar Nova Categoria</a>
    <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="Index">Voltar ao ADM</a>
</div>

<div class="mb-4">
    <input id="searchInput" type="search" class="form-control form-control-lg" placeholder="Pesquisar categorias por nome..." autocomplete="off" />
</div>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma categoria cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var categoria in Model)
        {
            <div class="col list-search-card">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0" data-search-name>@categoria.nome</h5>
                            <span class="badge text-bg-@((categoria.status == EscolaDeCursosWebApp.Modulos.ModuloCategoria.Dominio.StatusCategoria.Ativo) ? "success" : "secondary") rounded-pill">
                                @categoria.status
                            </span>
                        </div>

                        <p class="card-text mb-4">@categoria.descricao</p>

                        <div class="mt-auto d-flex flex-wrap gap-2 justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="EditarCategoria" asp-route-id="@categoria.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-action="ExcluirCategoria" asp-route-id="@categoria.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        const searchInput = document.getElementById('searchInput');
        if (!searchInput) return;

        const cards = Array.from(document.querySelectorAll('.list-search-card'));

        searchInput.addEventListener('input', function () {
            const term = this.value.trim().toLowerCase();
            cards.forEach(card => {
                const name = card.querySelector('[data-search-name]')?.textContent?.toLowerCase() ?? '';
                card.style.display = term === '' || name.includes(term) ? '' : 'none';
            });
        });
    })();
</script>
