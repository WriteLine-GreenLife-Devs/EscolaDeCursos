@model List<EscolaDeCursosWebApp.Modulos.ModuloADM.Apresentacao.TurmaADMViewModel>

@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = "Turmas";
}

    <div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="ADM" asp-action="CadastrarTurma">Cadastrar Nova Turma</a>
    <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="ADM" asp-action="Index">Voltar ao ADM</a>
</div>

    <div class="mb-4">
    <input id="searchInput" type="search" class="form-control form-control-lg" placeholder="Pesquisar turmas por nome, curso, instrutor..." autocomplete="off" />
</div>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma turma cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var turma in Model)
        {
            <div class="col list-search-card" data-search-fields="@($"{turma.Nome} {turma.CursoNome} {turma.InstrutorNome} {turma.HorarioTurno}")">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0" data-search-name>@turma.Nome</h5>
                            <span class="badge text-bg-@((turma.Status == EscolaDeCursosWebApp.Modulos.ModuloTurma.Dominio.StatusTurma.InscricoesAbertas) ? "warning text-dark" : "success") rounded-pill">
                                @turma.Status
                            </span>
                        </div>

                        <p class="card-text small text-muted mb-2">Curso: @turma.CursoNome</p>
                        <p class="card-text small text-muted mb-2">Instrutor: @turma.InstrutorNome</p>
                        <p class="card-text small text-muted mb-2">Inicio: @turma.DataInicio.ToString("d")</p>
                        <p class="card-text small text-muted mb-2">Fim: @turma.DataFim.ToString("d")</p>
                        <p class="card-text small text-muted mb-2">Vagas: @turma.VagasMaximas</p>
                        <p class="card-text small text-muted mb-2">Turno: @turma.HorarioTurno</p>

                        <div class="mt-auto d-flex flex-wrap gap-2 justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="EditarTurma" asp-route-id="@turma.Id">Editar</a>
                            <a class="btn btn-outline-secondary btn-sm rounded-pill px-3" asp-controller="ADM" asp-action="VerTurma" asp-route-id="@turma.Id">VerTurma</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-action="ExcluirTurma" asp-route-id="@turma.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        const searchInput = document.getElementById('searchInput');
        if (!searchInput) return;

        const cards = Array.from(document.querySelectorAll('.list-search-card'));

        searchInput.addEventListener('input', function () {
            const term = this.value.trim().toLowerCase();
            cards.forEach(card => {
                const fields = (card.dataset.searchFields || '').toLowerCase();
                card.style.display = term === '' || fields.includes(term) ? '' : 'none';
            });
        });
    })();
</script>
