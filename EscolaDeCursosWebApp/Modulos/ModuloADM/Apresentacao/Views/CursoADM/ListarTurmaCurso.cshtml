@model List<EscolaDeCursosWebApp.Modulos.ModuloADM.Apresentacao.TurmaADMViewModel>

@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = ViewBag.CursoNome ?? "Turmas do Curso";
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="ADM" asp-action="ListarCursos">Voltar</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma turma cadastrada para este curso.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var turma in Model)
        {
            <div class="col list-search-card" data-search-fields="@($"{turma.Nome} {turma.HorarioTurno} {turma.InstrutorNome} {turma.Status}")">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0" data-search-name>@turma.Nome</h5>
                            <div>
                                <span class="badge text-bg-@((turma.Status == EscolaDeCursosWebApp.Modulos.ModuloTurma.Dominio.StatusTurma.EmAndamento) ? "success" : "secondary") rounded-pill">
                                    @turma.Status
                                </span>
                            </div>
                        </div>

                        <p class="card-text mb-2">Instrutor: @turma.InstrutorNome</p>
                        <p class="card-text small text-muted mb-3">Período: @turma.DataInicio.ToString("d") - @turma.DataFim.ToString("d")</p>
                        <p class="card-text small text-muted mb-3">Horário/Turno: @turma.HorarioTurno</p>
                        <p class="card-text small text-muted mb-3">Vagas Máximas: @turma.VagasMaximas</p>

                        <div class="mt-auto d-flex flex-wrap gap-2 justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-controller="ADM" asp-action="EditarTurma" asp-route-id="@turma.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-controller="ADM" asp-action="ExcluirTurma" asp-route-id="@turma.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        // Client-side search uses the site's shared script for data-search-fields.
    })();
</script>
