@{
    Layout = "_LayoutADM";
    ViewBag.Titulo = "Alunos";
}

@model List<EscolaDeCursosWebApp.Modulos.ModuloADM.Apresentacao.UsuarioADMViewModel>;

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="CadastrarAluno">Cadastrar Novo Aluno</a>
    <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="Index">Voltar ao ADM</a>
</div>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum aluno cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var aluno in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@aluno.Nome</h5>
                            <span class="badge text-bg-primary rounded-pill">Aluno</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-6 text-secondary fw-semibold">Email</dt>
                            <dd class="col-6 mb-0 text-break">@aluno.Email</dd>

                            <dt class="col-6 text-secondary fw-semibold">Telefone</dt>
                            <dd class="col-6 mb-0 text-break">@aluno.Telefone</dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="EditarAluno" asp-route-id="@aluno.Id">Editar</a>
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-action="ExcluirAluno" asp-route-id="@aluno.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
