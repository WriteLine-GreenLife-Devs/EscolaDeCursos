@{
    Layout = "_LayoutPaginaInicial";
    ViewBag.Titulo = "Login";
}

<div class="d-flex align-items-center justify-content-center min-vh-75">
    <div class="card shadow-sm w-100" style="max-width: 420px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h2 class="h4 fw-semibold">Acessar a plataforma</h2>
                <p class="text-secondary mb-0">Use seu email e senha para entrar.</p>
            </div>

            <form asp-controller="Usuario" asp-action="Login" method="post">
                <div class="mb-3">
                    <label for="Email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="Email" name="Email" placeholder="seu@email.com" required>
                </div>

                <div class="mb-4">
                    <label for="Senha" class="form-label">Senha</label>
                    <input type="password" class="form-control" id="Senha" name="Senha" placeholder="Senha" required>
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-primary btn-lg">Login</button>
                    <a class="btn btn-outline-secondary btn-lg" asp-controller="Usuario" asp-action="CadastrarAluno">Cadastrar como aluno</a>
                </div>
            </form>
        </div>
    </div>
</div>
