@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row g-2">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Escola de Cursos Web</h1>
        <p class="lead text-secondary mb-4">
            Bem-vindo à Escola de Cursos Web!
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Exemplo" asp-action="Listar">Exemplo</a>
        </div>

    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
                <h3 class="h5 mb-3" style="color: #fff4e8;">Módulos disponíveis</h3>

                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Exemplo" asp-action="Listar">
                        Exemplo
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
